@page "/"

<PageTitle>Papelaria Admin</PageTitle>


<div class="text-center">
    <img src="Imagens/logop.png" alt="Logo da Papelaria" width="150" />
    <h1>Bem-vindo ao Sistema da Papelaria</h1>
</div>


<div class="home-container">

    <div class="banner-home">
        <div>
            <h1>Bem-vinda ao Sistema da Papelaria </h1>
            <p>
                Gerencie estoque, vendas, caixa e fornecedores
                de forma simples e organizada.
            </p>
        </div>
    </div>

    <!-- CARDS -->
    <div class="cards-home">

        <a href="/controleestoque" class="card-home">
