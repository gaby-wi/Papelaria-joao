        </a>

        <a href="/registrovendas" class="card-home">
            <div class="icone-card"></div>
            <h2> Controle de Vendas</h2>
        </a>

        <a href="/caixa" class="card-home">
            <div class="icone-card"></div>
            <h2>Caixa</h2>
        </a>

        <a href="/fornecedor" class="card-home">
            <div class="icone-card"></div>
            <h2>Fornecedor</h2>
        </a>


        <a href="/cadastroproduto" class="card-home">
            <div class="icone-card"></div>
            <h2>Cadastro de Produto</h2>
        </a>

        <a href="/Relatorios" class="card-home">
            <div class="icone-card"></div>
            <h2>Relatorios</h2>
        </a>

    </div>

</div>