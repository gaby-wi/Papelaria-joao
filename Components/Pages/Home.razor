@page "/"


<PageTitle>Home - Papelaria</PageTitle>

<div class="container mt-5" </div>


    <h1 class="fw-bold">Papelaria App</h1>

    <p class="text-muted">
        Bem-vindo ao sistema de gerenciamento da papelaria.
    </p>

<PageTitle>Papelaria Admin</PageTitle>

<div class="home-container">

    <!-- TOPO -->
    <div class="banner-home">
        <div>
            <h1>Bem-vinda ao Sistema da Papelaria </h1>
            <p>
                Gerencie estoque, vendas, caixa e fornecedores
                de forma simples e organizada.
            </p>
        </div>

        <div class="emoji">
            
        </div>
    </div>

    <!-- CARDS -->
    <div class="cards-home">

        <a href="/estoque" class="card-home">
            <div class="icone-card"></div>
            <h2>Estoque</h2>
            <p>Gerencie os produtos disponíveis</p>
        </a>

        <a href="/vendas" class="card-home">
            <div class="icone-card"></div>
            <h2>Vendas</h2>
            <p>Registre e acompanhe vendas</p>
        </a>

        <a href="/caixa" class="card-home">
            <div class="icone-card"></div>
            <h2>Caixa</h2>
            <p>Controle entradas e saídas</p>
        </a>

        <a href="/fornecedor" class="card-home">
            <div class="icone-card"></div>
            <h2>Fornecedor</h2>
            <p>Gerencie seus fornecedores</p>
        </a>

    </div>

    <!-- RESUMO -->
    <div class="resumo-home">

        <div class="mini-card">
            <h3>Vendas do Dia</h3>
            <span>R$ 450,00</span>
        </div>

        <div class="mini-card">
            <h3>Produtos</h3>
            <span>120</span>
        </div>

        <div class="mini-card">
            <h3>Pedidos</h3>
            <span>15</span>
        </div>

        <div class="mini-card">
            <h3>Estoque Baixo</h3>
            <span>8</span>
        </div>

    </div>


</div>