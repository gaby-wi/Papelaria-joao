<!-- Formulário para cadastro de novos produtos -->
@page "/cadastroproduto"

<PageTitle>Cadastro de Produtos</PageTitle>

<div class="home-container">

    <div class="container">

        <h1>Cadastro de Produtos</h1>

        <!-- Campo para informar o código do produto -->
        <div>
            <label>Código do Produto:</label><br />
            <input type="text" @bind="codigo" />
        </div>

        <br />

        <!-- Campo para informar o nome do produto -->
        <div>
            <label>Nome do Produto:</label><br />
            <input type="text" @bind="nome" />
        </div>

        <br />

        <!-- Lista de categorias disponíveis -->
        <div>
            <label>Categoria:</label><br />
            <select @bind="categoria">
                <option>Informática</option>
                <option>Eletrônicos</option>
                <option>Periféricos</option>
                <option>Outros</option>
            </select>
        </div>

        <br />

        <!-- Campo para informar o preço -->
        <div>
            <label>Preço:</label><br />
            <input type="number" @bind="preco" />
        </div>

        <br />

        <!-- Campo para informar a quantidade em estoque -->
        <div>
            <label>Quantidade:</label><br />
            <input type="number" @bind="quantidade" />
        </div>

        <br />

        <!-- Campo para descrição do produto -->
        <div>
            <label>Descrição:</label><br />
            <textarea @bind="descricao"></textarea>
        </div>

        <br />

        <!-- Botão responsável por cadastrar o produto -->
        <button @onclick="CadastroProduto">
            Cadastrar Produto
        </button>

        @if (!string.IsNullOrEmpty(mensagem))
        {
            <h3>@mensagem</h3>
        }

    </div>

</div>

<!-- Lógica da página -->
@code {
    // Variáveis que armazenam os dados do formulário
    string codigo = "";
    string nome = "";
    string categoria = "";
    decimal preco;
    int quantidade;
    string descricao = "";
    string mensagem = "";

    // Método executado ao clicar no botão de cadastro
    void CadastroProduto()
    {
        mensagem = $"Produto '{nome}' cadastrado com sucesso!";
    }
}