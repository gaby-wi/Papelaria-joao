@page "/estoque"

<div class="estoque-container">

    <!-- Barra Superior -->
    <div class="topo-roxo"></div>

    <div class="cabecalho">

        <div class="logo-area">
            <img src="/images/logo.png" class="logo" alt="Logo">
        </div>

        <div class="search-box">
            <input type="text" placeholder="Que você está procurando">
            <span>🔍</span>
        </div>

        <div class="icones">
            <span>💬</span>
            <span>🔔</span>
            <span>👤</span>
        </div>

    </div>

    <div class="faixa"></div>

    <div class="conteudo">

        <div class="produtos-grid">

            <!-- PRODUTO 1 -->
            <div class="produto-card">
                <h3>#1</h3>
                <img src="/images/produto1.png">
                <p>Caderno Kawaii 200 Pg 10 Matérias</p>
                <span>Quantidade: 32x</span>
                <h4>BR IMPORTS</h4>
            </div>

            <!-- PRODUTO 2 -->
            <div class="produto-card">
                <h3>#2</h3>
                <img src="/images/produto2.png">
                <p>Kit Escolar Canetas estilo desenho</p>
                <span>Quantidade: 9x</span>
                <h4>DUDA STORE</h4>
            </div>

            <!-- PRODUTO 3 -->
            <div class="produto-card">
                <h3>#3</h3>
                <img src="/images/produto3.png">
                <p>Caderno Kawaii 200 Pg 10 Matérias</p>
                <span>Quantidade: 12x</span>
                <h4>PARAMANGUE</h4>
            </div>

            <!-- PRODUTO 4 -->
            <div class="produto-card">
                <h3>#4</h3>
                <img src="/images/produto4.png">
                <p>Kit Escolar Completo</p>
                <span>Quantidade: 5x</span>
                <h4>DONSHOP</h4>
            </div>

            <!-- PRODUTO 5 -->
            <div class="produto-card">
                <h3>#5</h3>
                <img src="/images/produto5.png">
                <p>Estojo Moranguinho</p>
                <span>Quantidade: 23x</span>
                <h4>ABC PAPERS</h4>
            </div>

            <!-- PRODUTO 6 -->
            <div class="produto-card">
                <h3>#6</h3>
                <img src="/images/produto6.png">
                <p>Caderno Dark Side 100 Pg</p>
                <span>Quantidade: 59x</span>
                <h4>METEORS</h4>
            </div>

            <!-- PRODUTO 7 -->
            <div class="produto-card">
                <h3>#7</h3>
                <img src="/images/produto7.png">
                <p>Caneta Luxo Unicórnio</p>
                <span>Quantidade: 64x</span>
                <h4>FLOY SHOP</h4>
            </div>

            <!-- PRODUTO 8 -->
            <div class="produto-card">
                <h3>#8</h3>
                <img src="/images/produto8.png">
                <p>Estojo Minimalista Preto e Branco</p>
                <span>Quantidade: 21x</span>
                <h4>DANI BUY</h4>
            </div>

        </div>

    </div>

</div>