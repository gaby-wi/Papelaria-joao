@page "/login"
@inject NavigationManager NavigationManager

<div class="login-container">
    <div class="login-card shadow-lg">
        <div class="login-header text-center">
            <div class="logo-icon mb-3">
                <i class="bi bi-pencil-fill"></i>
            </div>
            <h2 class="fw-bold text-primary">Papelaria Admin</h2>
            <p class="text-muted">Bem-vindo de volta! Faça login para gerenciar sua loja.</p>
        </div>

        <form @onsubmit="HandleLogin">
            <div class="mb-3">
                <label for="email" class="form-label">E-mail</label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="bi bi-envelope"></i></span>
                    <input type="email" class="form-control" id="email" placeholder="admin@papelaria.com" required @bind="loginEmail" />
                </div>
            </div>
            <div class="mb-4">
                <label for="password" class="form-label">Senha</label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="bi bi-lock"></i></span>
                    <input type="password" class="form-control" id="password" placeholder="••••••••" required @bind="loginPassword" />
                </div>
            </div>
            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary btn-lg shadow-sm">Entrar</button>
            </div>
        </form>

        <div class="mt-4 text-center">
            <a href="#" class="text-decoration-none text-muted small">Esqueceu a senha?</a>
        </div>
    </div>
</div>

<style>
    .login-container {
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .login-card {
        background: white;
        padding: 2.5rem;
        border-radius: 1.5rem;
        width: 100%;
        max-width: 450px;
        border: none;
    }

    .logo-icon {
        font-size: 3rem;
        color: #0d6efd;
        background: #e7f1ff;
        width: 80px;
        height: 80px;
        line-height: 80px;
        border-radius: 50%;
        margin: 0 auto;
    }

    .form-control:focus {
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
        border-color: #0d6efd;
    }

    .btn-primary {
        background-color: #0d6efd;
        border: none;
        padding: 0.8rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-primary:hover {
            background-color: #0b5ed7;
            transform: translateY(-1px);
        }
</style>

@code {
    private string loginEmail = "";
    private string loginPassword = "";

    private void HandleLogin()
    {
        // Simulação de login
        NavigationManager.NavigateTo("/");
    }
}
